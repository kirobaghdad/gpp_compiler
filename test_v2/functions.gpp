int square(int x) {
    return x * x;
}

int sumWithDefault(int x, int y = 4) {
    int result = x + y;
    return result;
}

void storeResult(int value) {
    int last = value;
    if (last > 0) {
        return;
    }

    return;
}

int factorial(int n) {
    if (n <= 1) {
        return 1;
    }

    return n * factorial(n - 1);
}

int main() {
    int value = 3;
    int result = square(value);

    {
        int value = 5;
        int scoped = sumWithDefault(value);
        {
            int value = sumWithDefault(scoped, 2);
            result = result + value;
        }
        result = result + scoped;
    }

    result = result + factorial(4);
    storeResult(result);
    return result;
}
